{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "state_parser",
      "camelcase": "StateParser",
      "title": "StateParser",
      "scope": "source.state_parser",
      "file-types": [
        "state_parser"
      ],
      "injection-regex": "^state_parser$",
      "class-name": "TreeSitterStateParser"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "description": "StateParser grammar"
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}