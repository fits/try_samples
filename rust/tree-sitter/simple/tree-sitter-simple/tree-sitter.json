{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "simple",
      "camelcase": "Simple",
      "title": "Simple",
      "scope": "source.simple",
      "file-types": [
        "simple"
      ],
      "injection-regex": "^simple$",
      "class-name": "TreeSitterSimple"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Simple grammar for tree-sitter"
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}