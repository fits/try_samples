  "metadata": {
    "version": "0.1.0",
    "description": "StateDiagram grammar"
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
